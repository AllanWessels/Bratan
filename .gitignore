# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
.eggs/
build/
dist/
*.pyc

# Env
.env
.env.local

# User-owned project config (written by the setup wizard, per-machine state)
bratan.config.yaml
.bratan-setup.json

# Vector store
.chroma/
*.chroma/
*.sqlite3

# Reports (history kept in git, but transient lock/wip files ignored)
reports/*.lock
reports/.wip/

# Generated test cases stay in git; ephemeral drafts do not
test_cases/.drafts/

# Corpus is user data, not project artifact. Only the docs anchor is tracked.
corpus/*
!corpus/README.md
!corpus/.gitkeep

# UI
ui/frontend/node_modules/
ui/frontend/dist/
ui/frontend/.vite/
ui/frontend/coverage/
ui/frontend/.tsbuildinfo-node/
ui/frontend/*.tsbuildinfo
ui/frontend/test-results/
ui/frontend/playwright-report/
ui/backend/.cache/

# Caches
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Logs
*.log
logs/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
