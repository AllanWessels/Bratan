# --- Anthropic (oracle judge + agent runs) ---
ANTHROPIC_API_KEY=

# --- Local vLLM server (prejudge + optional generation) ---
# Run `vllm serve Qwen/Qwen2.5-14B-Instruct-AWQ --port 8001` on the host with the GPU.
VLLM_BASE_URL=http://localhost:8001
VLLM_PREJUDGE_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# --- Corpus + vector store ---
CORPUS_PATH=./corpus
CHROMA_PATH=./.chroma

# --- UI server ---
UI_HOST=127.0.0.1
UI_PORT=8000

# --- Optional: dev-only overrides ---
# BRATAN_LOG_LEVEL=INFO
